# ReachIQ Environment Variables

# AI Integration — Get a free key at https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Override default ports
# PORT=3001 (API)
# PORT=3002 (Channel Service)
# PORT=3000 (Web Frontend)

# Database (local SQLite — auto-configured)
# DATABASE_URL=file:./packages/db/prisma/dev.db

# Production: Set this if hosting frontend separately
# NEXT_PUBLIC_API_URL=https://your-api-domain.com
